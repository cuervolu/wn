{
  "id": "wn",
  "name": "wn",
  "scopeName": "source.wn",
  "aliases": ["cl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#module_access" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#stdlib_modules" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.wn"
    },
    "strings": {
      "name": "string.quoted.wn",
      "begin": "[\"']",
      "end": "[\"']",
      "patterns": [
        {
          "match": "\\\\[ntr\\\\\"']",
          "name": "constant.character.escape.wn"
        }
      ]
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.wn"
    },
    "module_access": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(::)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "entity.name.namespace.wn" },
        "2": { "name": "punctuation.separator.namespace.wn" },
        "3": { "name": "entity.name.function.wn" }
      }
    },
    "keywords": {
      "match": "\\b(wea|duro|pega|cachai|si|no|mientras|para|en|ojo|cago|devolver|cortala|sigue|queri|como)\\b",
      "name": "keyword.control.wn"
    },
    "builtins": {
      "match": "\\b(lorea|largo|cachar|pregunta|numero|texto)\\b",
      "name": "support.function.builtin.wn"
    },
    "stdlib_modules": {
      "match": "\\b(cadena|lista|mate|io)\\b(?=::)",
      "name": "entity.name.namespace.wn"
    },
    "literals": {
      "match": "\\b(verdad|falso|nada)\\b",
      "name": "constant.language.wn"
    },
    "operators": {
      "match": "\\b(y|o)\\b|::|[+\\-*/%=<>!]=?|==|!=",
      "name": "keyword.operator.wn"
    },
    "identifiers": {
      "match": "[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.wn"
    }
  }
}